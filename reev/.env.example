# Copy this file to .env and fill in your values
# cp .env.example .env

# REEV backend
BACKEND_CORS_ORIGINS=["http://localhost", "http://localhost:8080"]
SECRET_KEY=<generate_with: openssl rand -hex 32>
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=<your_superuser_password>

# Postgres (password managed via Docker secret file, see secrets/)
POSTGRES_SERVER=postgres
POSTGRES_USER=reev
POSTGRES_PASSWORD_FILE=/run/secrets/db-password
POSTGRES_DB=reev

# pgAdmin
PGADMIN_LISTEN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD_FILE=/run/secrets/pgadmin-password
PGADMIN_DISABLE_POSTFIX=true

# Celery / Flower
FLOWER_BASIC_AUTH=admin:<your_flower_password>

# Volume / config paths (NAS or local)
volumes_basedir=/mnt/pi-nas/raid-hdd/swarm-storage/reev-data
config_basedir=/mnt/pi-nas/raid-hdd/swarm-storage/reev-data
secrets_basedir=/home/arkantu/workspace/docker/genomic-stack/reev/secrets

# Lab config
LAB_NAME=Neuropediatría Genómica

# SMTP (Gmail: use an App Password from myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=<16_char_gmail_app_password>
SMTP_FROM=your_email@gmail.com
SMTP_TLS=true

# Variant tracker alerts
ALERT_WEBHOOK_URL=
ALERT_EMAIL_TO=your_email@gmail.com

# Variant tracker DB password (same as DB password in secrets/db-password)
VARTRACKER_DB_PASSWORD=<your_postgres_password>
